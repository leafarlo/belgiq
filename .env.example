# BelgiQ Environment Variables
# Copy to .env and fill in values — never commit .env to git

# Database
DATABASE_URL=postgresql://belgiq:yourpassword@localhost/belgiq

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# AI — Claude API for bill summarisation (weekly pipeline)
ANTHROPIC_API_KEY=sk-ant-...

# Environment
ENVIRONMENT=development   # or: production

# Optional: news API for commotion score updates
# NEWSAPI_KEY=your_key_here
